PORT=4101
HOST=0.0.0.0
# Set ke domain production frontend saat deploy.
ORIGIN=http://127.0.0.1:4101
PUBLIC_APP_NAME=MessHub
# Biarkan relative path ini jika Nginx me-route frontend/backend split.
PUBLIC_API_BASE_URL=/api/v1
# Wajib valid untuk server-side load/action SvelteKit.
PRIVATE_API_BASE_URL=http://127.0.0.1:4100/api/v1
