APP_NAME=MessHub
APP_VERSION=dev
APP_ENV=production
LOG_LEVEL=info
PORT=4100
BACKEND_HOST=0.0.0.0
DATABASE_URL=postgres://messhub:messhub@127.0.0.1:5432/messhub?sslmode=disable
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN_HOURS=72
# Gunakan origin production aktual, pisahkan banyak origin dengan koma.
CORS_ORIGIN=http://127.0.0.1:4101,http://localhost:4101
# Optional override kalau reverse proxy belum mengatur CSP sendiri.
CONTENT_SECURITY_POLICY=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'

SEED_ADMIN_NAME=MessHub Admin
SEED_ADMIN_EMAIL=admin@messhub.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_ROLE=admin
